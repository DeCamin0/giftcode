# === Discord ===
DISCORD_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_application_client_id
DISCORD_GUILD_ID=your_server_id_for_fast_command_sync

# Canal unde se postează codurile noi
GIFT_CODES_CHANNEL_ID=channel_id_for_new_codes

# Discord user IDs care pot folosi /addadmin și /removeadmin (separate prin virgulă)
OWNER_USER_IDS=your_discord_user_id

# Roluri Discord care au drepturi admin bot (R4 etc.) — separate prin virgulă
ADMIN_ROLE_IDS=123456789012345678,987654321098765432

# === MariaDB ===
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=kingshot_bot
DB_PASSWORD=change_me_strong_password
DB_NAME=kingshot_alliance

# === Gift code scheduler (cron UTC) ===
CHECK_CODES_ENABLED=true
CHECK_CODES_CRON=0 */2 * * *

# Gift codes: secondary source jeab.dev (true = both kingshot.net + jeab.dev)
JEAB_GIFT_CODES_ENABLED=true

# /getinfo — paste X-API-Token from kingshot.jeab.dev (Network tab, any /api/players request)
JEABS_API_TOKEN=

# === Redeem automat ===
# true = scheduler + /redeemall canjează pentru toți jucătorii înregistrați
ENABLE_AUTO_REDEEM=true

# Delay random între jucători la /redeemall (secunde)
REDEEM_MIN_DELAY_SECONDS=3
REDEEM_MAX_DELAY_SECONDS=8
